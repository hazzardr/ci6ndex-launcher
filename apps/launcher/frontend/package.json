{
  "name": "launcher",
  "private": true,
  "version": "0.1.0",
  "author": {
    "name": "brian",
    "email": "rbrianhazzard@gmail.com"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "vue-tsc -b --noEmit",
    "check:watch": "vue-tsc -b --noEmit --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint ."
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.14",
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.2.0",
    "globals": "^16.3.0",
    "jiti": "^2.4.2",
    "less": "^4.4.0",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.4",
    "vue": "^3.5.17",
    "vue-tsc": "^2.2.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
